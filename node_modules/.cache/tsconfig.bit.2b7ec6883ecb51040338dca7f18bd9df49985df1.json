{
  "compilerOptions": {
    "types": [
      "vitest/globals",
      "@testing-library/jest-dom",
      "node"
    ],
    "declaration": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "target": "es2020",
    "lib": [
      "esnext",
      "dom",
      "dom.Iterable"
    ],
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "../.."
  },
  "exclude": [
    "../../football/apps/football-prototype/artifacts",
    "../../football/apps/football-prototype/public",
    "../../football/apps/football-prototype/dist",
    "../../football/apps/football-prototype/node_modules",
    "../../football/apps/football-prototype/package.json",
    "../../football/apps/football-prototype/**/*.cjs",
    "../../football/apps/football-prototype/./dist"
  ],
  "include": [
    "../../football/apps/football-prototype/**/*",
    "../../football/apps/football-prototype/**/*.json",
    "./global-types/**/*"
  ]
}