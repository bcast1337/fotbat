#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/user/football-intel/node_modules/.pnpm/css-has-pseudo@3.0.4_postcss@8.4.19/node_modules/css-has-pseudo/node_modules:/home/user/football-intel/node_modules/.pnpm/css-has-pseudo@3.0.4_postcss@8.4.19/node_modules:/home/user/football-intel/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/user/football-intel/node_modules/.pnpm/css-has-pseudo@3.0.4_postcss@8.4.19/node_modules/css-has-pseudo/node_modules:/home/user/football-intel/node_modules/.pnpm/css-has-pseudo@3.0.4_postcss@8.4.19/node_modules:/home/user/football-intel/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../dist/cli.cjs" "$@"
else
  exec node  "$basedir/../../dist/cli.cjs" "$@"
fi
